# =============================================================================
# LLM Judge – Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# Storage Backend
# -----------------------------------------------------------------------------

# Which storage backend to use: gcs | local | s3 (stub) | azure (stub)
# Default: gcs
# Use 'local' for development and testing without GCP credentials.
STORAGE_PROVIDER=gcs

# Root directory for STORAGE_PROVIDER=local. Bucket names become subdirectories.
# Default: local-data   (resolved relative to the working directory)
# LOCAL_STORAGE_BASE_DIR=local-data

# Per-root provider overrides (optional). Each defaults to STORAGE_PROVIDER;
# GOLDEN defaults to the VERDICT provider. Lets one root use a different backend
# than the rest — e.g. read production logs from GCS but write verdicts locally:
#   STORAGE_PROVIDER=gcs
#   VERDICT_STORAGE_PROVIDER=local
# PRODUCTION_STORAGE_PROVIDER=gcs
# VERDICT_STORAGE_PROVIDER=local
# GOLDEN_STORAGE_PROVIDER=local

# -----------------------------------------------------------------------------
# GCS Buckets (required)
# -----------------------------------------------------------------------------

# The GCS bucket containing production logs (READ ONLY – never written to)
PRODUCTION_BUCKET=my-production-logs-bucket

# The GCS bucket where verdicts are written
VERDICT_BUCKET=my-verdict-bucket

# Optional: separate bucket for golden examples. Defaults to VERDICT_BUCKET.
# GOLDEN_BUCKET=my-golden-bucket

# Prefix inside VERDICT_BUCKET where verdict JSON files are stored
# Default: judge/
VERDICT_PREFIX=judge/

# Prefix inside GOLDEN_BUCKET where golden example JSON files are stored
# Default: golden/
GOLDEN_PREFIX=golden/

# Prefix inside VERDICT_BUCKET where run summary JSON files are stored
# Default: runs/
# RUNS_PREFIX=runs/

# -----------------------------------------------------------------------------
# GCP Authentication (optional – falls back to ADC)
# -----------------------------------------------------------------------------

# GCP project ID (optional, used for project-scoped GCS operations)
# GCP_PROJECT_ID=my-gcp-project

# Path to a service account key file (standard GCP ADC env var)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# -----------------------------------------------------------------------------
# LLM / Judge Model
# -----------------------------------------------------------------------------

# LLM provider. Only 'anthropic' is currently implemented.
JUDGE_LLM_PROVIDER=anthropic

# Anthropic API key (required)
JUDGE_LLM_API_KEY=sk-ant-...

# Claude model to use for judging
# Default: claude-sonnet-4-6
JUDGE_MODEL=claude-sonnet-4-6

# Optional: override the Anthropic API base URL (e.g. for private network proxy)
# JUDGE_LLM_BASE_URL=https://my-anthropic-proxy.internal/v1

# -----------------------------------------------------------------------------
# Judging Behavior
# -----------------------------------------------------------------------------

# Scores <= this value are considered failures and trigger flagging
# Default: 3
JUDGE_SCORE_THRESHOLD=3

# How many hours back to scan for logs in a standard run
# Default: 24
JUDGE_LOOKBACK_HOURS=24

# Maximum number of turns to evaluate in a single run (safety cap)
# Default: 500
JUDGE_MAX_TURNS_PER_RUN=500

# Number of parallel threads for evaluating turns
# Default: 5
JUDGE_MAX_WORKERS=5

# Maximum characters per input field before truncation
# Default: 150000
JUDGE_INPUT_TRUNCATE_CHARS=150000

# If parse errors in a run exceed this threshold, force-send an alert
# Default: 10
JUDGE_PARSE_ERROR_THRESHOLD=10

# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------

# Slack (or any) webhook URL for digest alerts
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Comma-separated list of email addresses to receive digest alerts
# ALERT_EMAILS=oncall@example.com,lead@example.com

# When false, skip sending alerts if no flags and no errors above threshold.
# When true (default), always send the daily digest.
ALERT_ON_SUCCESS=true

# -----------------------------------------------------------------------------
# SMTP (required only when ALERT_EMAILS is set)
# -----------------------------------------------------------------------------

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASSWORD=supersecret
# SMTP_FROM=llm-judge@example.com

# -----------------------------------------------------------------------------
# Dry Run
# -----------------------------------------------------------------------------

# When true, evaluate turns but do NOT write verdicts or send alerts
# Default: false
DRY_RUN=false
